# Backend environment configuration
# Copy this file to .env and fill in the values before starting the server.

# Required: must be a long random secret (e.g. openssl rand -hex 32)
PADEL_JWT_SECRET_KEY=

# JWT settings (defaults shown)
PADEL_JWT_ALGORITHM=HS256
PADEL_JWT_EXPIRE_MINUTES=480

# CORS: JSON array of allowed origins
PADEL_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# DuckDB file path (relative to the backend directory)
PADEL_DB_PATH=padel.duckdb
